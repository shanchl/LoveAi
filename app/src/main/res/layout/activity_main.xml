<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D"
    tools:context=".ui.MainActivity">

    <!-- ViewPager2 容器 -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:overScrollMode="never" />

    <!-- 顶部工具栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="40dp"
        android:orientation="horizontal"
        android:padding="16dp">

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 音乐按钮 -->
        <ImageButton
            android:id="@+id/btnMusic"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_circle_button"
            android:src="@drawable/ic_music"
            android:tint="#FFFFFF"
            android:contentDescription="音乐开关"
            android:padding="10dp" />

        <!-- 收藏列表按钮 -->
        <ImageButton
            android:id="@+id/btnFavorites"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle_button"
            android:src="@drawable/ic_heart"
            android:tint="#FFFFFF"
            android:contentDescription="@string/favorite"
            android:padding="10dp" />

    </LinearLayout>

    <!-- 底部控制栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="50dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 指示器圆点 -->
        <LinearLayout
            android:id="@+id/indicatorContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center" />

        <!-- 暂停/播放按钮 -->
        <ImageButton
            android:id="@+id/btnPlayPause"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_circle_button"
            android:src="@drawable/ic_pause"
            android:tint="#FFFFFF"
            android:contentDescription="@string/tap_to_pause"
            android:padding="14dp" />

    </LinearLayout>

    <!-- 底部音乐控制栏 -->
    <LinearLayout
        android:id="@+id/musicControlBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:background="#60000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="0dp">

        <!-- 上一首按钮 -->
        <ImageButton
            android:id="@+id/btnPrev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_prev"
            android:tint="#FFFFFF"
            android:contentDescription="上一首"
            android:padding="6dp" />

        <!-- 播放/暂停按钮 -->
        <ImageButton
            android:id="@+id/btnPlayPauseMusic"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_play"
            android:tint="#FFFFFF"
            android:contentDescription="播放/暂停"
            android:padding="8dp" />

        <!-- 歌曲名称 -->
        <TextView
            android:id="@+id/tvSongName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:singleLine="true"
            android:text="Love Music"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <!-- 下一首按钮 -->
        <ImageButton
            android:id="@+id/btnNext"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_next"
            android:tint="#FFFFFF"
            android:contentDescription="下一首"
            android:padding="6dp" />

        <!-- 播放列表按钮 -->
        <ImageButton
            android:id="@+id/btnPlaylist"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_music"
            android:tint="#FFFFFF"
            android:contentDescription="播放列表"
            android:padding="6dp" />

    </LinearLayout>

    <!-- 收藏按钮（固定在右下角） -->
    <ImageButton
        android:id="@+id/btnFavorite"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="140dp"
        android:background="@drawable/bg_circle_heart"
        android:src="@drawable/ic_heart"
        android:tint="#FFFFFF"
        android:contentDescription="@string/favorite"
        android:padding="16dp" />

    <!-- 重播按钮容器 -->
    <LinearLayout
        android:id="@+id/replayContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_replay_panel"
        android:padding="24dp"
        android:visibility="gone"
        android:alpha="0">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💕 本轮展示结束 💕"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="感谢你陪我走过这段旅程"
            android:textColor="#CCCCCC"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnReplay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_replay_button"
            android:text="再看一轮 ❤️"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp" />

    </LinearLayout>

</FrameLayout>
