<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#120B16"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="&#20316;&#21697;&#20013;&#24515;"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="&#31649;&#29702;&#33489;&#31295;&#12289;&#24050;&#21457;&#24067;&#26041;&#26696;&#21644;&#26368;&#36817;&#20351;&#29992;&#30340;&#28010;&#28459;&#20316;&#21697;"
        android:textColor="#CCFFFFFF"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCreatePlan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#26032;&#24314;&#26041;&#26696;" />

        <Button
            android:id="@+id/btnOpenExportCenter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="&#23548;&#20986;&#20013;&#24515;" />

        <Button
            android:id="@+id/btnOpenSmartGenerate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="AI &#29983;&#25104;" />
    </LinearLayout>

    <EditText
        android:id="@+id/etSearchPlan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="#26FFFFFF"
        android:hint="&#25628;&#32034;&#26041;&#26696;&#21517;&#25110;&#25991;&#26696;"
        android:padding="14dp"
        android:textColor="#FFFFFF"
        android:textColorHint="#88FFFFFF" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Spinner
            android:id="@+id/spThemeFilter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <Spinner
            android:id="@+id/spSortMode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1" />
    </LinearLayout>

    <Spinner
        android:id="@+id/spStatusFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp" />

    <TextView
        android:id="@+id/tvPlanStats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="#FFCFD8"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvEmptyPlans"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="&#36824;&#27809;&#26377;&#31526;&#21512;&#26465;&#20214;&#30340;&#26041;&#26696;"
        android:textColor="#CCFFFFFF"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPlans"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="24dp" />

</LinearLayout>
