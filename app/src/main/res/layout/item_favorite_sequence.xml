<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    android:background="#26FFFFFF"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/tvFavoriteName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvFavoriteSummary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="#CCFFFFFF"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvFavoriteTags"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#FFD7E8"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnOpenFavorite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#25171;&#24320;" />

        <Button
            android:id="@+id/btnEditFavorite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="&#32534;&#36753;" />

        <Button
            android:id="@+id/btnDeleteFavorite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="&#21024;&#38500;" />
    </LinearLayout>

</LinearLayout>
